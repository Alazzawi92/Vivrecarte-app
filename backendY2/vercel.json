{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "env": {
    "PORT": "5000",
    "DB_HOST": "@DB_HOST",
    "DB_USER": "@DB_USER",
    "DB_PASS": "@DB_PASS",
    "DB_NAME": "DB_NAME",
    "JWT_SECRET": "@JWT_SECRET",
    "SMTP_HOST": "@SMTP_HOST",
    "SMTP_USER": "@SMTP_USER",
    "SMTP_PASS": "@SMTP_PASS",
    "SMTP_PORT": "@SMTP_PORT",
    "SMTP_SENDER": "@SMTP_SENDER",
    "CLIENT_URL": "@CLIENT_URL"
  }
}